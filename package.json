{
  "name": "alice-assistant",
  "version": "0.0.1",
  "description": "An AI assistant with a customizable personality",
  "license": "MIT",
  "author": "",
  "type": "module",
  "bin": {
    "alice-assistant-start": "bin/alice-assistant-start",
    "alice-assistant-setup": "bin/alice-assistant-setup"
  },
  "main": "dist/lib.js",
  "scripts": {
    "build": "npm run build:server && npm run build:client && npm run build:plugin-ui",
    "build:server": "tsc && npm run post-build",
    "build:client": "esbuild src/plugins/system/web-ui/client/index.tsx --bundle --format=esm --platform=browser --target=es2022 --tsconfig=src/plugins/system/web-ui/client/tsconfig.client.json --outfile=dist/plugins/system/web-ui/client/alice-client.js",
    "build:plugin-ui": "esbuild src/plugins/community/mood/mood-web-ui.tsx --bundle --format=esm --platform=browser --target=es2022 --tsconfig=src/plugins/system/web-ui/client/tsconfig.client.json --outfile=dist/plugins/community/mood/mood-web-ui.js",
    "clean": "rm -rf dist",
    "post-build": "copyfiles -u 1 src/**/*.js dist/ && copyfiles -u 1 src/**/*.html dist/ && copyfiles -u 1 src/**/*.css dist/ && copyfiles -u 1 src/**/*.json dist/ && copyfiles -u 1 src/**/*.md dist/ && copyfiles -u 1 src/**/*.py dist/ && copyfiles -u 1 src/**/*.txt dist/",
    "lint:eslint": "eslint ./src --ext .ts,.tsx --fix",
    "lint:prettier": "prettier --write .",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:staged": "lint-staged",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@lightpanda/browser": "^1.2.0",
    "@mikro-orm/core": "^7.0.3",
    "@mikro-orm/sqlite": "^7.0.3",
    "blessed": "^0.1.81",
    "brave-search": "^0.9.0",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "mikro-orm": "^7.0.3",
    "ollama": "^0.6.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "retry-as-promised": "^7.1.1",
    "semver": "^7.7.4",
    "typebox": "^1.1.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.4",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
