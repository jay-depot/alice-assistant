{
  "compilerOptions": {
    "baseUrl": "./src",
    "target": "ES6",
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist/",
    "paths": {
      "@lib/*": ["lib/*"],
      "@entities/*": ["entities/*"],
      "@body-systems/*": ["body-systems/*"],
      "@genetics/*": ["genetics/*"],
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
